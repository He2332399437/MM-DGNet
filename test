import os
import numpy as np
import random
import torch
import pywt
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.metrics import confusion_matrix
import warnings
warnings.filterwarnings('ignore')


def set_seed(seed=42):
    random.seed(seed)
    np.random.seed(seed)
    torch.manual_seed(seed)
    torch.cuda.manual_seed(seed)
    torch.cuda.manual_seed_all(seed)
    torch.backends.cudnn.deterministic = True
    torch.backends.cudnn.benchmark = False
    os.environ['PYTHONHASHSEED'] = str(seed)
    print(f" {seed}")


class FeatureExtractor:
    def __init__(self, sample_length=2048, fs=12000):
        self.sample_length = sample_length
        self.fs = fs

    def extract_time_features(self, signal):

        mean = np.mean(signal, axis=2)  # [N, 3]
        std = np.std(signal, axis=2)
        rms = np.sqrt(np.mean(signal ** 2, axis=2))
        peak = np.max(np.abs(signal), axis=2)

        mean_expand = mean[:, :, np.newaxis]
        std_expand = std[:, :, np.newaxis] + 1e-8

        kurtosis = np.mean(((signal - mean_expand) / std_expand) ** 4, axis=2)
        skewness = np.mean(((signal - mean_expand) / std_expand) ** 3, axis=2)

        time_features = np.concatenate([mean, std, rms, peak, kurtosis, skewness], axis=1)

        return signal, time_features

    def extract_freq_features(self, signal):
        # signal: [N, 3, L]
        fft_vals = np.fft.fft(signal, axis=2)
        fft_mag = np.abs(fft_vals)[:, :, :self.sample_length // 2]  # [N, 3, L/2]

        max_vals = np.max(fft_mag, axis=2, keepdims=True) + 1e-8
        fft_mag = fft_mag / max_vals

        freq_features = fft_mag.reshape(fft_mag.shape[0], -1)

        return freq_features

    def extract_wavelet_features(self, signal, wavelet='db4', level=4):
        N, C, L = signal.shape
        wavelet_features = []

        for i in range(N):
            channel_features = []
            for ch in range(C):
                coeffs = pywt.wavedec(signal[i, ch, :], wavelet, level=level)
                energy = [np.sum(c ** 2) for c in coeffs]
                channel_features.extend(energy)
            wavelet_features.append(channel_features)

        return np.array(wavelet_features)  # [N, 3*5=15]


def extract_all_features(extractor, X):
    print(f" 🔍 输入数据形状: {X.shape}")

    time_data, time_features = extractor.extract_time_features(X)
    freq_data = extractor.extract_freq_features(X)
    wavelet_data = extractor.extract_wavelet_features(X)

    print(f"  {time_features.shape}")
    print(f" : {freq_data.shape}")
    print(f" : {wavelet_data.shape}")

    return time_data, time_features, freq_data, wavelet_data


labels_csv = ['A1', 'A2', 'A3', 'Normal']


def plot_confusion_matrix(y_true, y_pred, title, save_path, label_names=None):
    if label_names is None:
        label_names = labels_csv

    cm = confusion_matrix(y_true, y_pred)

    plt.figure(figsize=(10, 8))
    sns.heatmap(
        cm, annot=True, fmt='d', cmap='Blues',
        xticklabels=label_names, yticklabels=label_names
    )
    plt.title(title, fontsize=12)
    plt.ylabel('True Label', fontsize=11)
    plt.xlabel('Predicted Label', fontsize=11)
    plt.tight_layout()
    plt.savefig(save_path, dpi=300, bbox_inches='tight')
    plt.close()
