# ===================== CSV数据加载器(三通道) =====================
class CSVDataLoader:
    """✅ CSV数据加载器 - 支持三通道Ch1/Ch2/Ch3"""

    def __init__(self, data_dir, sample_length=2048, step=512):
        self.data_dir = data_dir
        self.sample_length = sample_length
        self.step = step

        # ✅ 四分类标签
        self.label_map = {"A1": 0, "A2": 1, "A3": 2, "normal": 3}

        # ✅ 四个域
        self.domains = ["1500_5", "1500_10", "1500_15", "1500_20"]
        self.domain2id = {d: i for i, d in enumerate(self.domains)}

    def load_csv_file(self, file_path):
        """加载CSV文件(三通道: Ch1, Ch2, Ch3)"""
        try:
            import pandas as pd
            df_head = pd.read_csv(file_path, nrows=5)
            has_header = any(isinstance(col, str) for col in df_head.columns)

            if has_header:
                df = pd.read_csv(file_path)

                # 查找Ch1, Ch2, Ch3列
                ch_cols = []
                for name in ["ch1", "ch2", "ch3"]:
                    matches = [c for c in df.columns if c.lower() == name]
                    if len(matches) > 0:
                        ch_cols.append(matches[0])

                if len(ch_cols) == 3:
                    signal = df[ch_cols].values.astype(np.float32)
                else:
                    print(f"⚠️ 未找到Ch1~Ch3列,使用后3列: {file_path}")
                    signal = df.iloc[:, -3:].values.astype(np.float32)
            else:
                df = pd.read_csv(file_path, header=None)
                if df.shape[1] < 3:
                    print(f"⚠️ 文件列数不足3列: {file_path}")
                    return None
                signal = df.iloc[:, -3:].values.astype(np.float32)

            return signal  # [N, 3]

        except Exception as e:
            print(f"⚠️ 加载文件失败 {file_path}: {e}")
            return None

    def sliding_window(self, signal):
        """滑动窗口切片(三通道)"""
        # signal: [N, 3]
        n_samples, n_channels = signal.shape

        if n_samples < self.sample_length:
            pad_len = self.sample_length - n_samples
            pad_array = np.zeros((pad_len, n_channels))
            signal = np.vstack([signal, pad_array])

        slices = []
        for i in range(0, len(signal) - self.sample_length + 1, self.step):
            seg = signal[i:i + self.sample_length, :].T  # 转为[3, L]
            slices.append(seg)

        if len(slices) == 0:
            seg = signal[:self.sample_length, :].T
            slices.append(seg)

        return np.array(slices, dtype=np.float32)  # [N_slices, 3, L]

    def get_label_from_filename(self, file_name):
        """从文件名提取标签"""
        lower = file_name.lower().replace('.csv', '')

        if "a1" in lower:
            return self.label_map["A1"]
        elif "a2" in lower:
            return self.label_map["A2"]
        elif "a3" in lower:
            return self.label_map["A3"]
        elif "normal" in lower:
            return self.label_map["normal"]

        print(f"⚠️ 无法识别文件名: {file_name}")
        return None

    def load_single_domain(self, domain_name, augment_for_train=True):
        """加载单个域的数据"""
        domain_path = os.path.join(self.data_dir, domain_name)
        if not os.path.exists(domain_path):
            print(f"⚠️ 域 {domain_name} 不存在,跳过")
            return None, None

        X_list, y_list = [], []
        csv_files = [f for f in os.listdir(domain_path) if f.endswith('.csv')]
        print(f"  📁 域 {domain_name} 包含文件: {csv_files}")

        for file_name in csv_files:
            label = self.get_label_from_filename(file_name)
            if label is None:
                continue

            file_path = os.path.join(domain_path, file_name)
            signal = self.load_csv_file(file_path)

            if signal is None or len(signal) == 0:
                continue

            samples = self.sliding_window(signal)
            X_list.append(samples)
            y_list += [label] * len(samples)

        if len(X_list) == 0:
            print(f"⚠️ 域 {domain_name} 没有有效数据")
            return None, None

        X = np.concatenate(X_list, axis=0)
        y = np.array(y_list)

        print(f"  ✅ 域 {domain_name}: {X.shape[0]}样本, 形状:{X.shape}, 标签:{np.bincount(y)}")
        return X, y

    def load_all_domains(self, augment_for_train=True):
        """加载所有域"""
        all_data = {}
        for domain in self.domains:
            X, y = self.load_single_domain(domain, augment_for_train=augment_for_train)
            if X is not None:
                all_data[domain] = (X, y)
        return all_data

    def load_cross_domain_data(self, test_domain):
        """跨域划分:留一域测试"""
        all_data = self.load_all_domains(augment_for_train=True)
        X_train_list, y_train_list, dom_train_list = [], [], []
        X_test, y_test = None, None

        for domain, (X, y) in all_data.items():
            domain_id = self.domain2id[domain]
            if domain == test_domain:
                X_test, y_test = X, y
            else:
                X_train_list.append(X)
                y_train_list.append(y)
                dom_train_list.append(np.full(len(y), domain_id, dtype=int))

        if len(X_train_list) == 0:
            print(f"⚠️ 没有训练数据")
            return None, None, None, None, None

        X_train = np.concatenate(X_train_list, axis=0)
        y_train = np.concatenate(y_train_list, axis=0)
        domain_train = np.concatenate(dom_train_list, axis=0)

        print(f"\n📊 跨域划分(测试域:{test_domain}):")
        print(f"  训练集:{X_train.shape}, 标签:{np.bincount(y_train)}")
        print(f"  测试集:{X_test.shape}, 标签:{np.bincount(y_test)}")

        return X_train, y_train, domain_train, X_test, y_test
# ===================== ✅ 特征提取器(三通道优化版) =====================
class FeatureExtractor:
    def __init__(self, sample_length=2048, fs=12000):
        self.sample_length = sample_length
        self.fs = fs

    def extract_time_features(self, signal):
        """✅ 三通道时域特征提取"""
        # signal: [N, 3, L]

        # 沿时间轴(axis=2)计算统计量
        mean = np.mean(signal, axis=2)  # [N, 3]
        std = np.std(signal, axis=2)
        rms = np.sqrt(np.mean(signal ** 2, axis=2))
        peak = np.max(np.abs(signal), axis=2)

        mean_expand = mean[:, :, np.newaxis]
        std_expand = std[:, :, np.newaxis] + 1e-8

        kurtosis = np.mean(((signal - mean_expand) / std_expand) ** 4, axis=2)
        skewness = np.mean(((signal - mean_expand) / std_expand) ** 3, axis=2)

        # ✅ 按通道拼接: [N, 3*6=18]
        time_features = np.concatenate([mean, std, rms, peak, kurtosis, skewness], axis=1)

        return signal, time_features

    def extract_freq_features(self, signal):
        """✅ 三通道频域特征提取"""
        # signal: [N, 3, L]
        fft_vals = np.fft.fft(signal, axis=2)
        fft_mag = np.abs(fft_vals)[:, :, :self.sample_length // 2]  # [N, 3, L/2]

        # 归一化
        max_vals = np.max(fft_mag, axis=2, keepdims=True) + 1e-8
        fft_mag = fft_mag / max_vals

        # ✅ 展平为 [N, 3*1024=3072]
        freq_features = fft_mag.reshape(fft_mag.shape[0], -1)

        return freq_features

    def extract_wavelet_features(self, signal, wavelet='db4', level=4):
        """✅ 三通道小波特征提取"""
        # signal: [N, 3, L]
        N, C, L = signal.shape
        wavelet_features = []

        for i in range(N):
            channel_features = []
            for ch in range(C):
                coeffs = pywt.wavedec(signal[i, ch, :], wavelet, level=level)
                energy = [np.sum(c ** 2) for c in coeffs]
                channel_features.extend(energy)
            wavelet_features.append(channel_features)

        return np.array(wavelet_features)  # [N, 3*5=15]
# ===================== 数据集类 =====================
class CWRUDataset(Dataset):
    def __init__(self, time_data, time_features, freq_data, wavelet_data, labels, domain_ids=None):
        self.time_data = torch.FloatTensor(time_data)
        self.time_features = torch.FloatTensor(time_features)
        self.freq_data = torch.FloatTensor(freq_data)
        self.wavelet_data = torch.FloatTensor(wavelet_data)
        self.labels = torch.LongTensor(labels)
        if domain_ids is not None:
            self.domain_ids = torch.LongTensor(domain_ids)
        else:
            self.domain_ids = torch.zeros(len(labels), dtype=torch.long)

    def __len__(self):
        return len(self.labels)

    def __getitem__(self, idx):
        return {
            'time_data': self.time_data[idx],
            'time_features': self.time_features[idx],
            'freq_data': self.freq_data[idx],
            'wavelet_data': self.wavelet_data[idx],
            'label': self.labels[idx],
            'domain': self.domain_ids[idx]
        }
